border diskBorder(t=0, 2*pi) {
    x = cos(t);
    y = sin(t);
};

mesh Th = buildmesh(diskBorder(100));

fespace Vh(Th, P1);

Vh u, v;

func f1 = 1;
func f2 = 0;

solve Poisson(u, v)=
int2d(Th)(dx(u)*dx(v)+dy(u)*dy(v))
- int2d(Th)(f2*v)
+ on(1, u=0);

plot(u, value=true, fill=true, cmm="Solution with f=1");