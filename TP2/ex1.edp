verbosity = 2;

real[int] xc = [0, 1, 1, 0, 0], yc = [0, 0, 1, 1, 0];
int[int] nn = [10, 10, 10, 10];

border domainBorder(t=0,1;i)
{
    x = xc[i] + t*(xc[i+1]-xc[i]);
    y = yc[i] + t*(yc[i+1]-yc[i]);
    label = i;
};

mesh domain = buildmesh(domainBorder(nn));

fespace Vh(domain, P1);

func f = x*y;

Vh u, v;

solve Poisson(u,v) = int2d(domain)(dx(u)* dx(v) + dy(u)*dy(v)) - int2d(domain)(f*v) + on(1,2,3,4,u=0);

plot(u, value=true);
