mesh Carre=square(5,3);
// plot(Carre);

border C1(t=0,1){x=t; y=0;};
border C2(t=0,1){x=1; y=t;};
border C3(t=0,1){x=1-t; y=1;};
border C4(t=0,1){x=0; y=1-t;};

mesh Carre2=buildmesh(C1(5)+C2(5)+C3(5)+C4(5));
// plot(Carre2);

border DiskBorder(t=0,2*pi){x=2*cos(t); y=2*sin(t);};
mesh Disk=buildmesh(DiskBorder(100));
// plot(Disk);


mesh Union=buildmesh(DiskBorder(100)+C1(100)+C2(100)+C3(100)+C4(100));
// plot(Union);

mesh Hole=buildmesh(DiskBorder(100)+C1(-30)+C2(-30)+C3(-30)+C4(-30));
// plot(Hole);

real[int] xc=[1.0,0.0,-1.0,0.0,0.0,1.0], yc=[0.0,1.0,0.0,-1.0,0.0,0.0];
int[int] nn=[10,10,10,20,20];
border polygon(t=0,1;i)
{
x = xc[i]+t*(xc[i+1]-xc[i]);
y = yc[i]+t*(yc[i+1]-yc[i]);
label = i;
};
mesh Th= buildmesh(polygon(nn));
plot(Th,wait=true);
